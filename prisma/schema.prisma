generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  label     String
  image     String   @default("")
  createdAt DateTime @default(now())
}

model Collection {
  id        String   @id @default(cuid())
  name      String   @unique
  image     String   @default("")
  createdAt DateTime @default(now())
}

model Product {
  id               String   @id @default(cuid())
  name             String
  productNumber    String   @default("")
  category         String
  collection       String
  price            Float
  image            String
  images           String   @default("[]")
  isNew            Boolean  @default(true)
  inStock          Boolean  @default(true)
  description      String   @default("")
  material         String   @default("")
  weight           String   @default("")
  size             String   @default("")
  stock            Int      @default(0)
  careInstructions String   @default("")
  createdAt        DateTime @default(now())
}

model User {
  id         String    @id @default(cuid())
  name       String?
  email      String    @unique
  phone      String?
  password   String
  role       String    @default("USER")
  otpCode    String?
  otpExpires DateTime?
  createdAt  DateTime  @default(now())
}

